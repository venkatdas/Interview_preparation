### 4. HTTP Caching Headers

```js
// Public data — browser and CDN can cache for 1 day
res.set('Cache-Control', 'public, max-age=86400');

// User-specific data — browser can cache but CDN cannot
res.set('Cache-Control', 'private, max-age=300');

// ETag — conditional request: browser sends ETag back, server returns 304 if unchanged
// 304 = no body = saves bandwidth
const etag = generateETag(data);
res.set('ETag', etag);
if (req.headers['if-none-match'] === etag) {
  return res.status(304).end(); // data unchanged — don't resend it
}
```

