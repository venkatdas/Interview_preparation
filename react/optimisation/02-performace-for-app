### 6. Avoid N+1 Queries

**The N+1 problem:** 1 query to get a list → N more queries for each item in the list.

```js
// BAD — 1 query for orders + 1 query per order for the user = N+1
const orders = await Order.find({ status: 'pending' });
for (const order of orders) {
  order.user = await User.findById(order.userId); // executes N times
}

// GOOD option 1 — 2 queries total using $in
const orders  = await Order.find({ status: 'pending' }).lean();
const userIds = [...new Set(orders.map(o => o.userId.toString()))];
const users   = await User.find({ _id: { $in: userIds } }).lean();
const userMap = Object.fromEntries(users.map(u => [u._id.toString(), u]));
orders.forEach(o => { o.user = userMap[o.userId.toString()]; });

// GOOD option 2 — $lookup in aggregation (single DB round-trip)
const orders = await Order.aggregate([
  { $match: { status: 'pending' } },
  { $lookup: {
    from: 'users',
    localField: 'userId',
    foreignField: '_id',
    as: 'user',
    pipeline: [{ $project: { name: 1, email: 1 } }] // only fetch needed fields
  }},
  { $unwind: '$user' }
]);
```

